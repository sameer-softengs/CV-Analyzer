{
    "version": 2,
    "builds": [
        {
            "src": "api.py",
            "use": "@vercel/python"
        }
    ],
    "rewrites": [
        {
            "source": "/analyze",
            "destination": "/api.py"
        },
        {
            "source": "/health",
            "destination": "/api.py"
        },
        {
            "source": "/docs",
            "destination": "/api.py"
        },
        {
            "source": "/openapi.json",
            "destination": "/api.py"
        },
        {
            "source": "/",
            "destination": "/index.html"
        }
    ]
}