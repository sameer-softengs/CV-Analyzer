{
    "version": 2,
    "builds": [
        {
            "src": "api.py",
            "use": "@vercel/python"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "^/(analyze|health|docs|openapi\\.json)$",
            "dest": "/api.py"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "^/$",
            "dest": "/public/index.html"
        },
        {
            "src": "^/(.*)$",
            "dest": "/public/$1"
        }
    ]
}